---
import Layout from './Layout.astro';
import Container from '../components/Container.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PageHero from '../components/sections/PageHero.astro';
import CtaBand from '../components/sections/CtaBand.astro';
import FaqSection from '../components/sections/FaqSection.astro';
import BenefitCard from '../components/ui/BenefitCard.astro';
import Icon from '../components/ui/Icon.astro';
import Button from '../components/Button.astro';
import { site } from '../data/site';
import { programsBySlug } from '../data/programs';
import { solutionsBySlug } from '../data/solutions';
import type { Program } from '../data/programs';
import { testimonialDisclaimer } from '../data/testimonials';
import { breadcrumbSchema, faqSchema, serviceSchema, combineSchema } from '../utils/seo';

interface Props {
  program: Program;
  /** Controls the breadcrumb trail and hub link wording. */
  kind?: 'program' | 'solution';
}

const { program, kind = 'program' } = Astro.props;

const hubHref = kind === 'solution' ? '/solutions' : '/loan-programs';
const hubLabel = kind === 'solution' ? 'Solutions' : 'Loan Programs';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: hubLabel, href: hubHref },
  { label: program.name, href: program.href },
];

const relatedItems = program.related
  .map((slug) => programsBySlug[slug] ?? solutionsBySlug[slug])
  .filter((item): item is Program => Boolean(item));

const benefitIcons = ['target', 'compass', 'shield-check', 'zap'];

const schema = combineSchema(
  serviceSchema({ name: program.name, description: program.seoDescription, url: program.href }),
  breadcrumbSchema(crumbs),
  faqSchema(program.faqs)
);
---

<Layout
  title={program.seoTitle}
  description={program.seoDescription}
  image={program.image}
  schema={schema}
>
  <div data-program-name={program.name} data-program-type={kind} class="hidden"></div>

  <PageHero
    eyebrow={kind === 'solution' ? 'Signature Solution' : 'Loan Program'}
    title={program.heroHeading}
    subtitle={program.blurb}
    image={program.heroImage}
    imageAlt={`${program.name} financing with The Herbert Team`}
    crumbs={crumbs}
  />

  <!-- ------------------------------------------------------------ intro + who -->
  <Section bg="white">
    <div class="grid gap-12 lg:grid-cols-[1.15fr_1fr] lg:gap-16">
      <div>
        <h2 class="text-h2 text-navy">{program.name}: What You Need to Know</h2>
        <p class="mt-5 text-body-lg text-graytext">{program.intro}</p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button
            href={site.applyUrl}
            variant="primary"
            icon="arrow-right"
            external
            track="begin_application"
            trackParams={{ cta_location: `${program.slug}_intro` }}
          >
            Start Your Application
          </Button>
          <Button href="/schedule" variant="secondary" track="schedule">Ask Me a Question First</Button>
        </div>
      </div>

      <div class="rounded-card border border-silver-light bg-offwhite p-7 md:p-8">
        <h2 class="font-heading text-h3 text-navy">Who This Is For</h2>
        <ul class="mt-5 space-y-4">
          {
            program.forWho.map((item) => (
              <li class="flex items-start gap-3">
                <Icon name="check-circle" size={20} class="mt-0.5 shrink-0 text-success" />
                <span class="text-[0.9375rem] leading-relaxed text-charcoal">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Section>

  <slot name="after-intro" />

  <!-- ------------------------------------------------------------ how it works -->
  <Section bg="offwhite">
    <SectionHeading
      eyebrow="How It Works"
      title={`Your ${program.name} Roadmap`}
      subtitle="No mystery steps, no waiting a week to hear back. Here is exactly how the process runs from first call to closing table."
      align="center"
      class="mb-12"
    />
    <ol class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {
        program.steps.map((step, index) => (
          <li class="reveal relative rounded-card border border-silver-light bg-white p-6 shadow-card" data-reveal-delay={index * 60}>
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-navy font-heading text-lg font-bold text-white tabular">
              {index + 1}
            </span>
            <h3 class="mt-4 font-heading text-lg font-bold text-navy">{step.title}</h3>
            <p class="mt-2 text-[0.9375rem] leading-relaxed text-graytext">{step.text}</p>
          </li>
        ))
      }
    </ol>
  </Section>

  <!-- ------------------------------------------------------------ benefits -->
  <Section bg="white">
    <SectionHeading
      eyebrow="Key Benefits"
      title="Why Borrowers Choose This Program"
      align="center"
      class="mb-12"
    />
    <div class="grid gap-6 md:grid-cols-2">
      {
        program.benefits.map((benefit, index) => (
          <BenefitCard
            title={benefit.title}
            text={benefit.text}
            icon={benefitIcons[index % benefitIcons.length] ?? 'check-circle'}
            class="reveal"
          />
        ))
      }
    </div>
  </Section>

  <slot name="after-benefits" />

  <!-- ------------------------------------------------------------ at a glance -->
  <Section bg="offwhite">
    <div class="grid gap-10 lg:grid-cols-[1fr_1.3fr] lg:gap-16">
      <div>
        <SectionHeading
          eyebrow="At a Glance"
          title="The Numbers, Plainly"
          align="left"
          subtitle="Guidelines shown are general and current as of publication. Program availability varies by state, property, and borrower eligibility, and all loans are subject to full underwriting approval."
        />
      </div>
      <dl class="overflow-hidden rounded-card border border-silver-light bg-white shadow-card">
        {
          program.glance.map((row, index) => (
            <div class:list={['flex flex-col gap-1 px-6 py-5 sm:flex-row sm:items-baseline sm:gap-6', index % 2 === 1 ? 'bg-offwhite' : '']}>
              <dt class="font-heading text-sm font-semibold uppercase tracking-wide text-graytext sm:w-2/5">
                {row.label}
              </dt>
              <dd class="flex-1 font-medium text-navy tabular">{row.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </Section>

  <!-- ------------------------------------------------------------ myths -->
  <Section bg="white">
    <SectionHeading
      eyebrow="Myths & Misconceptions"
      title="Things People Believe That Cost Them Money"
      align="center"
      class="mb-12"
    />
    <div class="grid gap-6 lg:grid-cols-3">
      {
        program.myths.map((item) => (
          <div class="reveal flex h-full flex-col rounded-card border border-silver-light bg-white p-7 shadow-card">
            <div class="flex items-start gap-3">
              <span class="mt-0.5 inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-silver-light text-graytext">
                <Icon name="x" size={16} />
              </span>
              <p class="font-heading font-semibold text-graytext line-through decoration-silver decoration-2">
                {item.myth}
              </p>
            </div>
            <div class="mt-5 flex items-start gap-3 border-t border-silver-light pt-5">
              <span class="mt-0.5 inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-success/10 text-success">
                <Icon name="check" size={16} />
              </span>
              <p class="text-[0.9375rem] leading-relaxed text-charcoal">{item.truth}</p>
            </div>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- ------------------------------------------------------------ testimonial -->
  <Section bg="navy" padding="sm">
    <div class="grid items-center gap-8 lg:grid-cols-[1.2fr_1fr]">
      <div>
        <p class="text-eyebrow font-heading font-semibold uppercase text-gold">Client Experience</p>
        <blockquote class="mt-4">
          <p class="font-heading text-h3 leading-snug text-white">&ldquo;{program.testimonial.quote}&rdquo;</p>
        </blockquote>
        <p class="mt-5 font-heading font-semibold text-white">{program.testimonial.author}</p>
        <p class="text-sm text-silver-light">{program.testimonial.role}</p>
        <p class="mt-6 max-w-2xl text-xs text-silver">{testimonialDisclaimer}</p>
      </div>
      <div class="rounded-card border border-white/15 bg-white/5 p-7">
        <h2 class="font-heading text-lg font-bold text-white">Not sure this is your program?</h2>
        <p class="mt-3 text-sm leading-relaxed text-silver-light">
          That is what the free strategy call is for. Twenty minutes, no obligation, and you leave knowing which
          financing path actually fits your situation.
        </p>
        <Button href="/schedule" variant="primary" class="mt-6" icon="arrow-right" track="schedule" fullWidth>
          Book a Free Strategy Call
        </Button>
      </div>
    </div>
  </Section>

  <slot name="before-faq" />

  <!-- ------------------------------------------------------------ faq -->
  <FaqSection
    eyebrow="Questions"
    title={`${program.name} FAQs`}
    items={program.faqs}
    idPrefix={program.slug}
    bg="offwhite"
  />

  <!-- ------------------------------------------------------------ related -->
  {
    relatedItems.length > 0 && (
      <Section bg="white" padding="sm">
        <Container class="px-0">
          <h2 class="font-heading text-h3 text-navy">Related Programs &amp; Solutions</h2>
          <div class="mt-6 grid gap-5 md:grid-cols-3">
            {relatedItems.map((item) => (
              <a
                href={item.href}
                class="group flex items-start gap-4 rounded-card border border-silver-light bg-white p-5 shadow-card transition-all duration-200 hover:-translate-y-1 hover:shadow-card-hover"
              >
                <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-brandblue-soft text-brandblue">
                  <Icon name={item.icon} size={22} />
                </span>
                <span>
                  <span class="block font-heading font-semibold text-navy">{item.name}</span>
                  <span class="mt-1 block text-sm leading-snug text-graytext">{item.tagline}</span>
                </span>
              </a>
            ))}
          </div>
        </Container>
      </Section>
    )
  }

  <CtaBand />
</Layout>
