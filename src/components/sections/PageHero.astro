---
import Container from '../Container.astro';
import Breadcrumbs from '../Breadcrumbs.astro';
import Button from '../Button.astro';
import { site } from '../../data/site';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  crumbs?: { label: string; href: string }[];
  showCtas?: boolean;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  align?: 'left' | 'center';
  size?: 'sm' | 'md';
}

const {
  eyebrow,
  title,
  subtitle,
  image = '/images/hero/about-hero.jpg',
  imageAlt = '',
  crumbs,
  showCtas = true,
  primaryLabel = 'Apply Online',
  primaryHref = site.applyUrl,
  secondaryLabel = 'Book a Free Strategy Call',
  secondaryHref = '/schedule',
  align = 'left',
  size = 'md',
} = Astro.props;

const isExternalPrimary = primaryHref.startsWith('http');
---

<section class="relative isolate overflow-hidden bg-navy">
  <img
    src={image}
    alt={imageAlt}
    width="1920"
    height="900"
    loading="eager"
    fetchpriority="high"
    decoding="async"
    class="absolute inset-0 h-full w-full object-cover"
  />
  <div class="absolute inset-0 bg-gradient-to-r from-navy/95 via-navy/85 to-navy/60" aria-hidden="true"></div>

  <Container class={`relative ${size === 'sm' ? 'py-14 md:py-16' : 'py-16 md:py-24 lg:py-28'}`}>
    {crumbs && <Breadcrumbs crumbs={crumbs} invert class="mb-6" />}
    <div class={align === 'center' ? 'mx-auto max-w-3xl text-center' : 'max-w-3xl'}>
      {
        eyebrow && (
          <p class="text-eyebrow font-heading font-semibold uppercase text-gold">{eyebrow}</p>
        )
      }
      <h1 class="mt-3 text-display text-white">{title}</h1>
      {subtitle && <p class="mt-6 text-body-lg text-silver-light">{subtitle}</p>}

      {
        showCtas && (
          <div class={`mt-9 flex flex-col gap-3 sm:flex-row ${align === 'center' ? 'sm:justify-center' : ''}`}>
            <Button
              href={primaryHref}
              variant="primary"
              size="lg"
              icon="arrow-right"
              external={isExternalPrimary}
              track={isExternalPrimary ? 'begin_application' : undefined}
              trackParams={isExternalPrimary ? { cta_location: 'page_hero' } : undefined}
            >
              {primaryLabel}
            </Button>
            <Button href={secondaryHref} variant="outline-white" size="lg" track="schedule">
              {secondaryLabel}
            </Button>
          </div>
        )
      }
      <slot />
    </div>
  </Container>
</section>
