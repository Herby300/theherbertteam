---
import Container from '../Container.astro';
import Button from '../Button.astro';
import Icon from '../ui/Icon.astro';
import { site } from '../../data/site';

interface Props {
  title?: string;
  subtitle?: string;
  class?: string;
}

const {
  title = 'Let\u2019s Solve Your Mortgage Situation.',
  subtitle = 'Apply online in about 12 minutes, or grab a free 20-minute strategy call. Either way, you\u2019ll leave knowing more than you do right now.',
  class: className = '',
} = Astro.props;
---

<section class={`bg-navy py-16 md:py-20 ${className}`}>
  <Container>
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-h2 text-white">{title}</h2>
      <p class="mt-5 text-body-lg text-silver-light">{subtitle}</p>
      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <Button
          href={site.applyUrl}
          variant="primary"
          size="lg"
          icon="arrow-right"
          external
          track="begin_application"
          trackParams={{ cta_location: 'cta_band' }}
        >
          Apply Online
        </Button>
        <Button href="/schedule" variant="outline-white" size="lg" track="schedule">
          Schedule Free Consultation
        </Button>
      </div>
      <p class="mt-6">
        <a
          href={site.phoneHref}
          class="inline-flex min-h-[44px] items-center gap-2 font-heading font-semibold text-white transition-colors hover:text-brandblue"
        >
          <Icon name="phone" size={18} class="text-brandblue" />
          <span>Or just call me directly — <span class="tabular">{site.phone}</span></span>
        </a>
      </p>
    </div>
  </Container>
</section>
