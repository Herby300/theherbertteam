---
import Container from '../Container.astro';
import Icon from '../ui/Icon.astro';
import GhlForm from '../forms/GhlForm.astro';
import { formIds } from '../../data/site';

interface Props {
  title?: string;
  description?: string;
  bullets?: string[];
  bg?: 'offwhite' | 'white' | 'soft';
  class?: string;
}

const {
  title = 'Free Homebuyer Guide',
  description = 'The whole picture in one download: what you can actually afford, what lenders look at, how much cash you need, and what happens between offer and closing.',
  bullets = [
    'How much house fits your budget, not just your approval',
    'The documents underwriting will ask for, listed up front',
    'Closing cost breakdown with real Texas numbers',
  ],
  bg = 'offwhite',
  class: className = '',
} = Astro.props;

const backgrounds: Record<string, string> = {
  offwhite: 'bg-offwhite',
  white: 'bg-white',
  soft: 'bg-brandblue-soft',
};
---

<section class={`${backgrounds[bg]} py-14 md:py-16 ${className}`}>
  <Container>
    <div class="grid items-center gap-8 rounded-card border border-silver-light bg-white p-6 shadow-card md:p-9 lg:grid-cols-2 lg:gap-12">
      <div>
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-brandblue-soft text-brandblue">
          <Icon name="book-open" size={24} />
        </span>
        <h2 class="mt-5 text-h3 font-bold text-navy">{title}</h2>
        <p class="mt-3 leading-relaxed text-graytext">{description}</p>
        <ul class="mt-5 space-y-2.5">
          {
            bullets.map((bullet) => (
              <li class="flex items-start gap-3 text-[0.9375rem] text-charcoal">
                <Icon name="check" size={18} class="mt-1 shrink-0 text-success" />
                <span>{bullet}</span>
              </li>
            ))
          }
        </ul>
        <p class="mt-5 text-sm text-graytext">No cost, no obligation, and your email is never sold or shared.</p>
      </div>
      <div class="overflow-hidden rounded-card border border-silver-light bg-offwhite p-2">
        <GhlForm formId={formIds.guideDownload} title="Free Homebuyer Guide Download" formType="guide_download" height="420" />
      </div>
    </div>
  </Container>
</section>
