---
import Icon from './Icon.astro';

interface Props {
  title: string;
  text: string;
  href: string;
  icon?: string;
  class?: string;
}

const { title, text, href, icon = 'home', class: className = '' } = Astro.props;
---

<a
  href={href}
  class={`group flex h-full flex-col rounded-card border border-silver-light bg-white p-6 shadow-card transition-all duration-200 hover:-translate-y-1 hover:border-brandblue/40 hover:shadow-card-hover ${className}`}
>
  <span
    class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-brandblue-soft text-brandblue transition-colors duration-200 group-hover:bg-brandblue group-hover:text-white"
  >
    <Icon name={icon} size={24} />
  </span>
  <h3 class="mt-5 font-heading text-lg font-bold text-navy">{title}</h3>
  <p class="mt-2 flex-1 text-[0.9375rem] leading-relaxed text-graytext">{text}</p>
  <span class="mt-5 inline-flex items-center gap-1.5 font-heading text-sm font-semibold text-brandblue">
    Learn more
    <Icon name="arrow-right" size={16} class="transition-transform duration-200 group-hover:translate-x-1" />
  </span>
</a>
