---
import Icon from './Icon.astro';

interface Props {
  invert?: boolean;
  class?: string;
  stats?: { value: string; label: string }[];
}

const {
  invert = false,
  class: className = '',
  stats = [
    { value: '5.0', label: 'Google Rating' },
    { value: '20+', label: 'Years of Experience' },
    { value: 'Thousands', label: 'of Families Served' },
  ],
} = Astro.props;
---

<div
  class:list={[
    'grid gap-6 rounded-card border p-6 sm:grid-cols-3 md:p-8',
    invert ? 'border-white/15 bg-white/5' : 'border-silver-light bg-white shadow-card',
    className,
  ]}
>
  {
    stats.map((stat, index) => (
      <div class="text-center">
        {index === 0 && (
          <div class="mb-2 flex items-center justify-center gap-1 text-gold" aria-hidden="true">
            {[0, 1, 2, 3, 4].map(() => (
              <Icon name="star" size={18} class="fill-current" strokeWidth={0} />
            ))}
          </div>
        )}
        <p class:list={['font-heading text-3xl font-extrabold tabular md:text-4xl', invert ? 'text-white' : 'text-navy']}>
          {stat.value}
        </p>
        <p class:list={['mt-1 text-sm', invert ? 'text-silver-light' : 'text-graytext']}>{stat.label}</p>
      </div>
    ))
  }
</div>
