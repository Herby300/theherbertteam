---
import Icon from './Icon.astro';

interface Props {
  question: string;
  /** Plain-text answer. Use the slot instead for rich content. */
  answer?: string;
  id: string;
  open?: boolean;
}

const { question, answer, id, open = false } = Astro.props;
const panelId = `${id}-panel`;
const triggerId = `${id}-trigger`;
---

<div class="bg-white">
  <h3 class="m-0">
    <button
      type="button"
      id={triggerId}
      class="flex w-full items-start justify-between gap-4 px-5 py-5 text-left transition-colors hover:bg-offwhite md:px-7"
      aria-expanded={open ? 'true' : 'false'}
      aria-controls={panelId}
      data-accordion-item-trigger
    >
      <span class="font-heading text-[1.0625rem] font-semibold text-navy md:text-lg">{question}</span>
      <span class="mt-0.5 shrink-0 text-brandblue">
        <Icon
          name="chevron-down"
          size={22}
          class={`transition-transform duration-200 ${open ? 'rotate-180' : ''}`}
        />
      </span>
    </button>
  </h3>
  <div id={panelId} role="region" aria-labelledby={triggerId} class={open ? 'px-5 pb-6 md:px-7' : 'hidden px-5 pb-6 md:px-7'}>
    {answer && <p class="max-w-3xl leading-relaxed text-graytext">{answer}</p>}
    <slot />
  </div>
</div>
