---
import Section from '../Section.astro';
import SectionHeading from '../SectionHeading.astro';
import TestimonialCard from '../ui/TestimonialCard.astro';
import StatBar from '../ui/StatBar.astro';
import GoogleReviews from '../ui/GoogleReviews.astro';
import Icon from '../ui/Icon.astro';
import { testimonials, testimonialDisclaimer } from '../../data/testimonials';
---

<Section bg="navy">
  <SectionHeading
    eyebrow="Real Clients. Real Closings."
    title="Don’t Take My Word For It."
    align="center"
    invert
    eyebrowColor="gold"
    class="mb-10"
  />

  <StatBar invert class="mx-auto max-w-4xl" />

  <!-- Static cards render in the HTML and are indexable; the live widget below is client-side. -->
  <ul
    class="snap-row mt-12 -mx-5 flex gap-5 overflow-x-auto px-5 pb-2 md:mx-0 md:grid md:grid-cols-3 md:gap-6 md:overflow-visible md:px-0"
  >
    {
      testimonials.map((testimonial) => (
        <li class="snap-item w-[85vw] shrink-0 sm:w-[70vw] md:w-auto">
          <TestimonialCard {...testimonial} invert class="h-full" />
        </li>
      ))
    }
  </ul>

  <div class="mt-10 rounded-card bg-white p-4 shadow-card md:p-6">
    <h3 class="mb-4 font-heading text-lg font-bold text-navy">Live reviews from Google</h3>
    <GoogleReviews minHeight="420px" />
  </div>

  <div class="mt-10 text-center">
    <a
      href="/reviews"
      class="inline-flex min-h-[48px] items-center gap-2 font-heading text-base font-semibold text-white transition-colors hover:text-brandblue"
    >
      Read All Reviews
      <Icon name="arrow-right" size={18} class="text-brandblue" />
    </a>
    <p class="mx-auto mt-6 max-w-2xl text-sm text-silver">{testimonialDisclaimer}</p>
  </div>
</Section>
