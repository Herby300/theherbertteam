---
import Container from '../Container.astro';
import Button from '../Button.astro';
import Icon from '../ui/Icon.astro';
import TrustBar from '../ui/TrustBar.astro';
import { site } from '../../data/site';

const outcomes = [
  {
    icon: 'zap',
    title: 'Get a real answer in 24 hours',
    text: 'not a runaround',
  },
  {
    icon: 'key-round',
    title: 'Qualify with income other lenders won\u2019t count',
    text: 'bank statement, 1099, P&L, DSCR',
  },
  {
    icon: 'shield-check',
    title: 'Know exactly what you\u2019re signing',
    text: 'every number explained before you commit',
  },
];
---

<section class="relative isolate overflow-hidden bg-navy">
  <div class="absolute inset-0 bg-gradient-to-br from-navy-light via-navy to-navy-dark" aria-hidden="true"></div>
  <div
    class="pointer-events-none absolute -right-32 top-1/2 h-[34rem] w-[34rem] -translate-y-1/2 rounded-full bg-brandblue/20 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <Container class="relative">
    <div class="grid gap-x-10 lg:min-h-[85vh] lg:grid-cols-12 lg:grid-rows-[auto_auto] lg:items-center">
      <div class="pt-14 sm:pt-20 lg:col-span-7 lg:row-start-1 lg:pt-24">
        <p class="text-eyebrow font-heading font-semibold uppercase text-gold">
          20+ Years · Licensed in Texas &amp; Nationwide
        </p>
        <h1 class="mt-4 font-heading text-display text-white">More Than a Mortgage. A Mortgage Solution.</h1>
        <p class="mt-6 max-w-2xl text-body-lg text-silver-light">
          Most lenders quote you a rate. I solve the problem standing between you and your home. Self-employed, buying
          before selling, or told &ldquo;no&rdquo; somewhere else — there&rsquo;s almost always a path. Let&rsquo;s find
          yours.
        </p>

        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <Button
            href={site.applyUrl}
            variant="primary"
            size="lg"
            icon="arrow-right"
            external
            track="begin_application"
            trackParams={{ cta_location: 'home_hero' }}
          >
            Apply Online
          </Button>
          <Button href="/schedule" variant="outline-white" size="lg" track="schedule">
            Book a Free Strategy Call
          </Button>
        </div>
      </div>

      <div class="mt-10 lg:col-span-5 lg:col-start-8 lg:row-span-2 lg:row-start-1 lg:mt-0 lg:self-end">
        <img
          src="/images/jason-headshot-hero.webp"
          alt="Jason Herbert, mortgage advisor with The Herbert Team in Georgetown, Texas"
          width="1100"
          height="1467"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="mx-auto block w-full max-w-[17rem] drop-shadow-2xl sm:max-w-[20rem] lg:max-w-none"
        />
      </div>

      <ul class="mb-14 mt-10 grid gap-5 sm:mb-20 sm:grid-cols-3 lg:col-span-7 lg:row-start-2 lg:mb-24 lg:mt-12">
        {
          outcomes.map((outcome) => (
            <li class="flex gap-3.5">
              <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-white/10 text-brandblue backdrop-blur">
                <Icon name={outcome.icon} size={22} />
              </span>
              <span>
                <span class="block font-heading text-[0.9375rem] font-semibold leading-snug text-white">
                  {outcome.title}
                </span>
                <span class="mt-1 block text-sm text-silver-light">{outcome.text}</span>
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </Container>

  <div class="relative border-t border-white/15 bg-navy-dark/70">
    <Container class="py-4">
      <TrustBar invert />
    </Container>
  </div>
</section>
