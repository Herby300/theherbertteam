---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/Section.astro';
import Icon from '../components/ui/Icon.astro';
import { site } from '../data/site';
import { breadcrumbSchema } from '../utils/seo';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Licensing & Disclosures', href: '/licensing' },
];

const stateLicenses = [
  ['Alabama', '23183'],
  ['Arizona', 'BK-1042893'],
  ['Arkansas', '128109'],
  ['California', '41DBO-166162'],
  ['District of Columbia', 'MLB1894879'],
  ['Illinois', 'MB.6761716'],
  ['Maine', '1894879'],
  ['Massachusetts (Mortgage Lender License)', 'ML1894879'],
  ['Michigan', 'FR0024371'],
  ['Minnesota', 'MO-OX-1894879'],
  ['Nevada', '5627'],
  ['New Mexico', 'Mortgage Loan Company License'],
  ['North Dakota (Mortgage Lender License)', 'ML104670'],
  ['Oregon', '1894879'],
  ['Rhode Island', '20254854LL'],
  ['Washington', 'CL-1894879'],
  ['West Virginia', 'ML-1894879'],
];
---

<PageLayout
  title="Licensing & Disclosures"
  description="NMLS licensing, state license numbers, Equal Housing Lender and FDIC disclosures for Jason Herbert (NMLS #633039) and Primis Mortgage Company (NMLS #1894879)."
  heroEyebrow="Compliance"
  heroTitle="Licensing & Disclosures"
  heroSubtitle="Everything on this page is verifiable through NMLS Consumer Access. If anything here is unclear, call me and I will walk you through it."
  heroImage="/images/hero/about-hero.jpg"
  heroImageAlt=""
  crumbs={crumbs}
  showHeroCtas={false}
  heroSize="sm"
  schema={breadcrumbSchema(crumbs)}
>
  <Section bg="white">
    <div class="mx-auto max-w-4xl">
      <!-- ------------------------------------------------------ identification -->
      <h2 class="text-h2 text-navy">Licensed Identification</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <div class="rounded-card border border-silver-light bg-offwhite p-7">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-lg bg-brandblue-soft text-brandblue">
            <Icon name="user" size={22} />
          </span>
          <h3 class="mt-4 font-heading text-lg font-bold text-navy">Individual</h3>
          <p class="mt-2 text-charcoal">{site.advisor}</p>
          <p class="mt-1 text-charcoal tabular">{site.nmls}</p>
          <a
            href={site.nmlsLookup}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex min-h-[44px] items-center gap-1.5 font-heading text-sm font-semibold text-brandblue hover:underline"
          >
            Verify on NMLS Consumer Access
            <Icon name="external-link" size={15} />
          </a>
        </div>

        <div class="rounded-card border border-silver-light bg-offwhite p-7">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-lg bg-brandblue-soft text-brandblue">
            <Icon name="landmark" size={22} />
          </span>
          <h3 class="mt-4 font-heading text-lg font-bold text-navy">Institution</h3>
          <p class="mt-2 text-charcoal">{site.institution}</p>
          <p class="mt-1 text-charcoal tabular">{site.institutionNmls}</p>
          <a
            href={site.institutionNmlsLookup}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex min-h-[44px] items-center gap-1.5 font-heading text-sm font-semibold text-brandblue hover:underline"
          >
            Verify on NMLS Consumer Access
            <Icon name="external-link" size={15} />
          </a>
        </div>
      </div>

      <!-- ------------------------------------------------------ state licenses -->
      <h2 class="mt-16 text-h2 text-navy">Primis Mortgage State Licenses</h2>
      <p class="mt-4 text-body-lg text-graytext">
        The following state license numbers apply to {site.institution}. This table is sourced from
        <a
          href="https://primisbank.com/disclosures/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-brandblue underline underline-offset-2">primisbank.com/disclosures</a
        > and should be re-verified against that page, as license numbers change.
      </p>

      <div class="mt-8 overflow-x-auto rounded-card border border-silver-light bg-white shadow-card">
        <table class="w-full min-w-[28rem] border-collapse text-left">
          <caption class="sr-only">Primis Mortgage Company state license numbers</caption>
          <thead>
            <tr class="bg-navy text-white">
              <th scope="col" class="px-5 py-4 font-heading text-sm font-semibold">State</th>
              <th scope="col" class="px-5 py-4 font-heading text-sm font-semibold">License number</th>
            </tr>
          </thead>
          <tbody>
            {
              stateLicenses.map(([state, license], index) => (
                <tr class={index % 2 === 1 ? 'bg-offwhite' : 'bg-white'}>
                  <th scope="row" class="border-b border-silver-light px-5 py-3.5 text-left font-medium text-navy">
                    {state}
                  </th>
                  <td class="border-b border-silver-light px-5 py-3.5 text-charcoal tabular">{license}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <!-- ------------------------------------------------------ why Texas is absent -->
      <h2 class="mt-16 text-h2 text-navy">Why Texas Is Not on the List</h2>
      <div class="mt-6 space-y-5 text-body-lg text-graytext">
        <p>
          If you look up {site.institution} on NMLS Consumer Access and do not find a Texas entry, that is expected and
          it does not mean lending in Texas is restricted.
        </p>
        <div class="rounded-card border-l-4 border-brandblue bg-brandblue-soft p-6 text-charcoal md:p-7">
          <p class="leading-relaxed">
            {site.institution} operates under the charter and federal regulatory authority of Primis Bank, Member FDIC.
            Where a state requires additional mortgage lender licensing, those license numbers are listed above. States
            not listed do not require separate licensure for a federally regulated bank.
          </p>
        </div>
        <p>
          In plain language: a federally regulated bank derives its mortgage lending authority from its bank charter,
          which preempts separate state mortgage-lender licensing in most states. The table above lists only the states
          that require additional licensure on top of that authority. Texas is absent because Texas does not require
          separate licensure for a federally regulated bank — not because lending there is limited in any way.
        </p>
      </div>
      <!-- TODO: Have Primis marketing compliance confirm the exact wording of the explanatory note above, and confirm
           whether the Texas Consumer Complaint and Recovery Fund Notice is required on this site. -->

      <!-- ------------------------------------------------------ state-specific -->
      <h2 class="mt-16 text-h2 text-navy">Additional State Disclosures</h2>
      <div class="mt-8 space-y-6">
        <div class="rounded-card border border-silver-light bg-offwhite p-7">
          <h3 class="font-heading text-lg font-bold text-navy">California</h3>
          <p class="mt-3 leading-relaxed text-charcoal">
            Licensed by the Department of Financial Protection and Innovation under the California Residential Mortgage
            Lending Act.
          </p>
        </div>

        <div class="rounded-card border border-silver-light bg-offwhite p-7">
          <h3 class="font-heading text-lg font-bold text-navy">Illinois</h3>
          <address class="mt-3 not-italic leading-relaxed text-charcoal">
            Illinois Department of Financial and Professional Regulation<br />
            320 West Washington Street, 3rd Floor<br />
            Springfield, Illinois 62786<br />
            <a href="tel:+18884734858" class="text-brandblue hover:underline">(888) 473-4858</a>
          </address>
        </div>
      </div>

      <!-- ------------------------------------------------------ equal housing / fdic -->
      <h2 class="mt-16 text-h2 text-navy">Equal Housing Lender &amp; FDIC</h2>
      <div class="mt-8 rounded-card border border-silver-light bg-offwhite p-7 md:p-8">
        <div class="flex flex-wrap items-center gap-6">
          <img
            src="/images/badges/equal-housing.svg"
            alt="Equal Housing Lender"
            width="56"
            height="56"
            class="h-14 w-auto"
            loading="lazy"
            decoding="async"
          />
          <img
            src="/images/badges/fdic.svg"
            alt="Member FDIC"
            width="112"
            height="56"
            class="h-14 w-auto"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="mt-6 space-y-4 leading-relaxed text-charcoal">
          <p>
            We do business in accordance with the Federal Fair Housing Law and the Equal Credit Opportunity Act. It is
            illegal to discriminate against any person because of race, color, religion, sex, handicap, familial status,
            national origin, or because all or part of the applicant&rsquo;s income derives from a public assistance
            program.
          </p>
          <p>{site.institution} is a division of Primis Bank, Member FDIC.</p>
        </div>
      </div>

      <!-- ------------------------------------------------------ lending disclosures -->
      <h2 class="mt-16 text-h2 text-navy">Lending Disclosures</h2>
      <div class="mt-6 space-y-4 leading-relaxed text-charcoal">
        <p>
          <strong class="text-navy">This is not a commitment to lend.</strong> All loans are subject to credit approval,
          income verification, and property appraisal. Not all applicants will qualify.
        </p>
        <p>
          <strong class="text-navy">Rates and terms are subject to change without notice.</strong> Any rates, payments,
          or terms referenced on this website are illustrative and do not constitute an offer of credit. Actual terms
          depend on your credit profile, loan amount, property type, occupancy, loan-to-value, and market conditions at
          the time of lock.
        </p>
        <p>
          <strong class="text-navy">Program availability varies.</strong> Loan programs described on this site vary by
          state, property type, and borrower eligibility, and may be discontinued or modified at any time. Guideline
          figures shown are general and are not a guarantee of eligibility.
        </p>
        <p>
          <strong class="text-navy">Calculators are estimates.</strong> Any calculator or payment example on this site is
          provided for educational purposes only and does not reflect an actual quote. Property tax and insurance
          amounts vary significantly by location and property.
        </p>
        <p>
          <strong class="text-navy">Testimonial disclaimer.</strong> Testimonials appearing on this site reflect
          individual experiences of clients who have used our services. They are individual results and results do vary.
          We do not claim that they are typical results, and testimonials are not a guarantee of future outcomes.
        </p>
        <p>
          <strong class="text-navy">Third-party links.</strong> This website may link to third-party sites, including the
          Primis Bank application portal and NMLS Consumer Access. We are not responsible for the content, privacy
          practices, or security of third-party websites.
        </p>
      </div>

      <div class="mt-12 rounded-card border border-silver-light bg-offwhite p-7">
        <p class="text-sm leading-relaxed text-graytext">
          {site.advisor} | {site.nmls} | {site.institution} | {site.institutionNmls}<br />
          Equal Housing Lender · Member FDIC<br />
          Last reviewed: {new Date().getFullYear()}. Questions about anything on this page? Call
          <a href={site.phoneHref} class="font-semibold text-brandblue hover:underline">{site.phone}</a>.
        </p>
      </div>
    </div>
  </Section>
</PageLayout>
