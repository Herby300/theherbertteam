---
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/Section.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ResourceCard from '../../components/ui/ResourceCard.astro';
import GhlForm from '../../components/forms/GhlForm.astro';
import Icon from '../../components/ui/Icon.astro';
import Button from '../../components/Button.astro';
import { resources } from '../../data/resources';
import { formIds } from '../../data/site';
import { breadcrumbSchema } from '../../utils/seo';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Resources', href: '/resources' },
];
---

<PageLayout
  title="Free Homebuyer Guides & Checklists"
  description="Download free homebuying guides, checklists, and closing cost breakdowns from a Georgetown, TX mortgage advisor. Real education, no sales pitch, no obligation."
  heroEyebrow="Resource Library"
  heroTitle="Free Guides, Zero Sales Pitch."
  heroSubtitle="Everything here is what I would tell you on a call, written down so you can read it at midnight when the question actually occurs to you. Give me an email address and it is yours."
  heroImage="/images/hero/resources-hero.jpg"
  heroImageAlt="Stack of homebuying guides on a desk"
  crumbs={crumbs}
  showHeroCtas={false}
  schema={breadcrumbSchema(crumbs)}
>
  <Section bg="offwhite">
    <SectionHeading
      eyebrow="Download Library"
      title="Seven Resources, All Free"
      subtitle="Written for real buyers in Texas, not generic national templates. Updated as guidelines and costs change."
      align="center"
      class="mb-12"
    />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        resources.map((resource) => (
          <ResourceCard
            title={resource.title}
            description={resource.description}
            image={resource.image}
            slug={resource.slug}
            icon={resource.icon}
            href={resource.slug === 'mortgage-calculator' ? '/resources/calculator' : undefined}
            class="reveal"
          />
        ))
      }
    </div>
  </Section>

  <Section bg="white">
    <div class="grid items-center gap-10 rounded-card bg-navy p-8 md:p-12 lg:grid-cols-[1.2fr_1fr]">
      <div>
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-brandblue text-white">
          <Icon name="calculator" size={24} />
        </span>
        <h2 class="mt-5 text-h2 text-white">Run the Numbers Yourself</h2>
        <p class="mt-4 text-body-lg text-silver-light">
          The mortgage calculator includes Texas property taxes, insurance, HOA dues, and PMI — plus a full amortization
          schedule so you can see exactly how much interest you pay over the life of the loan.
        </p>
      </div>
      <Button href="/resources/calculator" variant="primary" size="lg" icon="arrow-right" fullWidth>
        Open the Calculator
      </Button>
    </div>
  </Section>

  <Section bg="offwhite">
    <div class="grid gap-8 lg:grid-cols-2 lg:gap-12">
      <div class="rounded-card border border-silver-light bg-white p-7 shadow-card md:p-9">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-brandblue-soft text-brandblue">
          <Icon name="book-open" size={24} />
        </span>
        <h2 class="mt-5 text-h3 font-bold text-navy">Prefer Articles?</h2>
        <p class="mt-3 leading-relaxed text-graytext">
          The blog covers bank statement loans, VA entitlement, DSCR math, the Austin market, and whether buying points
          is worth it — all in plain English, all written by me rather than by a content agency.
        </p>
        <Button href="/blog" variant="secondary" class="mt-6" icon="arrow-right">Read the Blog</Button>
      </div>

      <div class="rounded-card border border-silver-light bg-white p-7 shadow-card md:p-9">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-brandblue-soft text-brandblue">
          <Icon name="mail" size={24} />
        </span>
        <h2 class="mt-5 text-h3 font-bold text-navy">Get New Resources by Email</h2>
        <p class="mt-3 leading-relaxed text-graytext">
          Occasional updates on rates, programs, and the Central Texas market. No spam, and one click unsubscribes.
        </p>
        <div class="mt-6 overflow-hidden rounded-card border border-silver-light">
          <GhlForm formId={formIds.newsletter} title="Newsletter Signup" formType="newsletter" height="320" />
        </div>
      </div>
    </div>
  </Section>
</PageLayout>
