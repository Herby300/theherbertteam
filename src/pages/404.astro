---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import Icon from '../components/ui/Icon.astro';
import CtaBand from '../components/sections/CtaBand.astro';
import { site } from '../data/site';

const popular = [
  { label: 'Apply Online', href: '/apply', text: 'Start your application in the secure Primis portal.', icon: 'send' },
  {
    label: 'Book a Strategy Call',
    href: '/schedule',
    text: 'Twenty free minutes to get real answers.',
    icon: 'calendar',
  },
  {
    label: 'Loan Programs',
    href: '/loan-programs',
    text: 'Conventional, FHA, VA, jumbo, construction, and more.',
    icon: 'home',
  },
  {
    label: 'Self-Employed Programs',
    href: '/loan-programs/self-employed',
    text: 'Bank statement, 1099, P&L, and no-ratio loans.',
    icon: 'briefcase',
  },
  { label: 'VA Loans', href: '/loan-programs/va-loans', text: 'Zero down, no monthly MI, entitlement reuse.', icon: 'shield-check' },
  {
    label: 'Refinance',
    href: '/loan-programs/refinance',
    text: 'Rate-and-term, cash-out, and no-lender-fee options.',
    icon: 'refresh-cw',
  },
  {
    label: 'Buy Before You Sell',
    href: '/solutions/buy-before-you-sell',
    text: 'Make a non-contingent offer without selling first.',
    icon: 'key-round',
  },
  {
    label: 'Down Payment Assistance',
    href: '/solutions/down-payment-assistance',
    text: 'Programs that shrink the cash you need to close.',
    icon: 'piggy-bank',
  },
  {
    label: 'Mortgage Calculator',
    href: '/resources/calculator',
    text: 'Run a full payment breakdown with taxes and insurance.',
    icon: 'calculator',
  },
  { label: 'Free Guides', href: '/resources', text: 'Seven downloadable guides, zero sales pitch.', icon: 'download' },
  { label: 'Blog', href: '/blog', text: 'Plain-English mortgage education and market updates.', icon: 'book-open' },
  { label: 'FAQ', href: '/faq', text: 'Every question I get asked, answered.', icon: 'help-circle' },
];
---

<Layout
  title="Page Not Found"
  description="The page you were looking for is not here. Find loan programs, guides, the mortgage calculator, or reach Jason Herbert directly."
  noindex
>
  <section class="bg-navy py-16 md:py-24">
    <Container>
      <div class="mx-auto max-w-3xl text-center">
        <span class="font-heading text-eyebrow font-semibold uppercase tracking-[0.12em] text-gold">Error 404</span>
        <h1 class="mt-4 text-display text-white">That Page Refinanced Into Something Else.</h1>
        <p class="mt-6 text-body-lg text-silver-light">
          The link is broken, the page moved, or the address has a typo in it. Nothing is wrong with your loan — let&rsquo;s
          get you back on track.
        </p>
        <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <Button href="/" variant="primary" size="lg" icon="arrow-right">Back to the Homepage</Button>
          <Button href={site.phoneHref} variant="outline-white" size="lg" icon="phone" iconPosition="left">
            Call {site.phone}
          </Button>
        </div>
      </div>
    </Container>
  </section>

  <Section bg="white">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-h2 text-navy">Try One of These Instead</h2>
      <p class="mt-3 text-body-lg text-graytext">Type a word to narrow the list — for example &ldquo;VA,&rdquo; &ldquo;calculator,&rdquo; or &ldquo;self-employed.&rdquo;</p>

      <div class="relative mx-auto mt-7 max-w-md">
        <span class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-graytext">
          <Icon name="search" size={20} />
        </span>
        <label for="page-search" class="sr-only">Search site pages</label>
        <input
          id="page-search"
          type="search"
          placeholder="Search pages..."
          autocomplete="off"
          class="min-h-[52px] w-full rounded-lg border border-silver bg-white py-3.5 pl-12 pr-4 text-base text-charcoal placeholder:text-graytext focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brandblue"
        />
      </div>
    </div>

    <ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" id="page-list">
      {
        popular.map((item) => (
          <li data-search-term={`${item.label} ${item.text}`.toLowerCase()}>
            <a
              href={item.href}
              class="flex h-full gap-4 rounded-card border border-silver-light bg-white p-5 shadow-card transition-all duration-200 hover:-translate-y-1 hover:shadow-card-hover"
            >
              <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-brandblue-soft text-brandblue">
                <Icon name={item.icon} size={20} />
              </span>
              <span>
                <span class="block font-heading font-bold text-navy">{item.label}</span>
                <span class="mt-1 block text-sm leading-relaxed text-graytext">{item.text}</span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    <p id="page-search-empty" class="mt-8 hidden text-center text-graytext">
      Nothing matched that. Call <a href={site.phoneHref} class="font-semibold text-brandblue hover:underline">{site.phone}</a>
      or <a href="/contact" class="font-semibold text-brandblue hover:underline">send a message</a> and I will point you to
      the right place.
    </p>
  </Section>

  <CtaBand
    title="Still Not Finding It?"
    subtitle="Tell me what you were looking for and I'll send you straight to it — or just answer the question directly."
  />
</Layout>

<script>
  const input = document.getElementById('page-search') as HTMLInputElement | null;
  const list = document.getElementById('page-list');
  const empty = document.getElementById('page-search-empty');

  if (input && list && empty) {
    const items = Array.from(list.querySelectorAll<HTMLLIElement>('[data-search-term]'));

    input.addEventListener('input', () => {
      const query = input.value.trim().toLowerCase();
      let visible = 0;

      items.forEach((item) => {
        const match = !query || (item.dataset.searchTerm ?? '').includes(query);
        item.hidden = !match;
        if (match) visible += 1;
      });

      empty.classList.toggle('hidden', visible > 0);
    });
  }
</script>
