---
import ProgramLayout from '../../layouts/ProgramLayout.astro';
import Section from '../../components/Section.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ComparisonTable from '../../components/ui/ComparisonTable.astro';
import Icon from '../../components/ui/Icon.astro';
import Button from '../../components/Button.astro';
import { getProgram } from '../../data/programs';

const program = getProgram('self-employed');

const documents = [
  { icon: 'file-text', title: 'Bank statement loan', items: ['12 or 24 months of business or personal bank statements', 'Business license or CPA letter confirming self-employment', 'Entity documents if you own through an LLC or corporation', 'Photo ID and a completed application'] },
  { icon: 'briefcase', title: '1099 loan', items: ['One or two years of 1099 forms', 'Year-to-date earnings documentation', 'Business license or CPA confirmation', 'Photo ID and a completed application'] },
  { icon: 'calculator', title: 'P&L loan', items: ['Profit and loss statement prepared by a CPA or licensed tax preparer', 'Two to three months of bank statements for support on some programs', 'Business license or CPA letter', 'Photo ID and a completed application'] },
  { icon: 'lock', title: 'No-ratio loan', items: ['No income documentation at all', 'Credit report and score', 'Verified assets for down payment and reserves', 'Photo ID and a completed application'] },
];

const denialReasons = [
  {
    reason: 'Your net income was too low after write-offs',
    fix: 'Bank statement or 1099 qualifying uses deposits or gross income instead of the net figure on Schedule C. For most business owners this multiplies qualifying income.',
  },
  {
    reason: 'Your income declined year over year',
    fix: 'Conventional underwriting averages two years and penalizes a decline. A 12-month bank statement program looks at the most recent year only, which frequently solves it.',
  },
  {
    reason: 'You have been self-employed less than two years',
    fix: 'Some programs accept one year of self-employment with documented prior experience in the same field. That is very common for people who left a W-2 job to do the same work independently.',
  },
  {
    reason: 'Your business and personal finances are mixed together',
    fix: 'Personal bank statement programs are built for exactly this. We use the account where the money actually lands rather than forcing a clean business-entity structure that does not exist.',
  },
  {
    reason: 'The lender did not have the program',
    fix: 'The most common reason of all. Many retail lenders only offer agency loans, so a file that needs alternative documentation gets a denial rather than a referral. That is not a reflection on your file.',
  },
];
---

<ProgramLayout program={program} kind="program">
  <Section slot="after-benefits" bg="white">
    <SectionHeading
      eyebrow="Compare the Four Programs"
      title="Same Borrower. Four Different Answers."
      subtitle="Which program you use can change your qualifying income by a factor of two or three. This is the comparison I run before recommending anything."
      align="center"
      class="mb-10"
    />
    <ComparisonTable
      headers={['', 'Bank Statement', '1099', 'P&L Only', 'No-Ratio']}
      rows={[
        ['Income proof used', '12–24 months of deposits', 'Gross 1099 income', 'CPA-prepared P&L', 'None'],
        ['Tax returns required', 'No', 'No', 'No', 'No'],
        ['Typical minimum credit', '620–660', '640', '660–680', '680–700'],
        ['Typical down payment', '10%–20%', '10%–20%', '15%–25%', '25%–30%'],
        ['Best for', 'Business owners with heavy write-offs', 'Contractors and consultants', 'Owners with clean CPA books', 'Complex or undocumentable income'],
        ['Documentation burden', 'Moderate', 'Light', 'Lightest with CPA support', 'Minimal'],
      ]}
      highlightColumn={1}
      class="mb-6"
    />
    <p class="mx-auto max-w-3xl text-center text-sm text-graytext">
      Guidelines shown are typical ranges across investors and are not an offer of credit. Actual terms depend on your
      full profile and are subject to underwriting approval.
    </p>
  </Section>

  <Section slot="before-faq" bg="white">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <SectionHeading
          eyebrow="Document Checklist"
          title="What You Actually Need to Send Me"
          align="left"
          subtitle="Notice what is missing from every one of these lists: two years of tax returns."
          class="mb-8"
        />
        <div class="space-y-5">
          {
            documents.map((doc) => (
              <div class="rounded-card border border-silver-light bg-white p-6 shadow-card">
                <div class="flex items-center gap-3">
                  <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-brandblue-soft text-brandblue">
                    <Icon name={doc.icon} size={20} />
                  </span>
                  <h3 class="font-heading text-lg font-bold text-navy">{doc.title}</h3>
                </div>
                <ul class="mt-4 space-y-2">
                  {doc.items.map((item) => (
                    <li class="flex items-start gap-2.5 text-[0.9375rem] text-charcoal">
                      <Icon name="check" size={17} class="mt-1 shrink-0 text-success" />
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>

      <div>
        <SectionHeading
          eyebrow="Why You Were Denied Elsewhere"
          title="Five Reasons, Five Fixes"
          align="left"
          subtitle="Send me the denial letter. Nine times out of ten the reason listed maps to one of these."
          class="mb-8"
        />
        <ol class="space-y-5">
          {
            denialReasons.map((item, index) => (
              <li class="rounded-card border border-silver-light bg-offwhite p-6">
                <div class="flex items-start gap-3">
                  <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-navy font-heading text-sm font-bold text-white tabular">
                    {index + 1}
                  </span>
                  <p class="font-heading font-semibold text-navy">{item.reason}</p>
                </div>
                <p class="mt-3 pl-11 text-[0.9375rem] leading-relaxed text-graytext">{item.fix}</p>
              </li>
            ))
          }
        </ol>

        <div class="mt-8 rounded-card border-l-4 border-brandblue bg-brandblue-soft p-6">
          <h3 class="font-heading text-lg font-bold text-navy">Already been told no?</h3>
          <p class="mt-2 leading-relaxed text-charcoal">
            Send me the denial reasons and 24 months of business bank statements. I will tell you within a business day
            whether there is a path — and if there genuinely is not one yet, what it would take to build it.
          </p>
          <Button href="/contact" variant="primary" class="mt-5" icon="arrow-right">Send Me Your Scenario</Button>
        </div>
      </div>
    </div>
  </Section>
</ProgramLayout>
