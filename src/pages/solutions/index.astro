---
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/Section.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import Icon from '../../components/ui/Icon.astro';
import Button from '../../components/Button.astro';
import { solutions } from '../../data/solutions';
import { breadcrumbSchema } from '../../utils/seo';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Solutions', href: '/solutions' },
];

const problems = [
  {
    problem: '“You have too much equity tied up and no way to reach it.”',
    solution: 'ATM Mortgage — a first-lien HELOC that keeps your equity liquid.',
    href: '/solutions/atm-mortgage',
  },
  {
    problem: '“You will need to sell your current home before we can approve you.”',
    solution: 'Buy Before You Sell — make a non-contingent offer and move once.',
    href: '/solutions/buy-before-you-sell',
  },
  {
    problem: '“Come back when you have saved more for a down payment.”',
    solution: 'Down Payment Assistance — grants and second liens that cover the gap.',
    href: '/solutions/down-payment-assistance',
  },
  {
    problem: '“You should probably rent for another year or two.”',
    solution: 'First-Time Homebuyer guidance — real numbers before you decide anything.',
    href: '/solutions/first-time-homebuyers',
  },
];
---

<PageLayout
  title="Mortgage Solutions for Tough Situations"
  description="Signature mortgage solutions from The Herbert Team: first-lien HELOC, buy before you sell, Texas down payment assistance, and first-time homebuyer guidance."
  heroEyebrow="Signature Solutions"
  heroTitle="The Problems Other Lenders Send You Home With."
  heroSubtitle="These four come up constantly, and each one has a real answer. Not a workaround — a structured program built for exactly that situation."
  heroImage="/images/hero/solutions-hero.webp"
  heroImageAlt="Couple reviewing mortgage options at a kitchen table"
  crumbs={crumbs}
  schema={breadcrumbSchema(crumbs)}
>
  <Section bg="white">
    <SectionHeading
      eyebrow="Sound Familiar?"
      title="Four Sentences You Should Never Accept as Final"
      subtitle="Every one of these is a program gap, not a verdict on your finances."
      align="center"
      class="mb-12"
    />
    <div class="grid gap-6 md:grid-cols-2">
      {
        problems.map((item) => (
          <div class="reveal flex h-full flex-col rounded-card border border-silver-light bg-white p-7 shadow-card">
            <p class="font-heading text-lg italic leading-snug text-graytext">{item.problem}</p>
            <div class="my-5 flex items-center gap-3">
              <span class="h-px flex-1 bg-silver-light" />
              <Icon name="arrow-down" size={18} class="text-brandblue" />
              <span class="h-px flex-1 bg-silver-light" />
            </div>
            <p class="flex-1 font-heading font-semibold text-navy">{item.solution}</p>
            <a
              href={item.href}
              class="mt-5 inline-flex min-h-[44px] items-center gap-1.5 font-heading text-sm font-semibold text-brandblue hover:text-brandblue-hover"
            >
              See how it works
              <Icon name="arrow-right" size={16} />
            </a>
          </div>
        ))
      }
    </div>
  </Section>

  <Section bg="offwhite">
    <SectionHeading
      eyebrow="Explore Each Solution"
      title="Built for Specific Situations"
      align="center"
      class="mb-12"
    />
    <div class="grid gap-8 lg:grid-cols-2">
      {
        solutions.map((solution) => (
          <article class="reveal flex h-full flex-col overflow-hidden rounded-card border border-silver-light bg-white shadow-card transition-shadow duration-200 hover:shadow-card-hover">
            <img
              src={solution.image}
              alt={`${solution.name} — ${solution.tagline}`}
              width="900"
              height="500"
              loading="lazy"
              decoding="async"
              class="aspect-[9/5] w-full object-cover"
            />
            <div class="flex flex-1 flex-col p-7">
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-brandblue-soft text-brandblue">
                <Icon name={solution.icon} size={24} />
              </span>
              <h3 class="mt-5 font-heading text-h3 text-navy">{solution.name}</h3>
              <p class="mt-3 flex-1 leading-relaxed text-graytext">{solution.blurb}</p>
              <Button href={solution.href} variant="primary" class="mt-6 self-start" icon="arrow-right">
                Learn about {solution.name}
              </Button>
            </div>
          </article>
        ))
      }
    </div>
  </Section>
</PageLayout>
