---
import ProgramLayout from '../../layouts/ProgramLayout.astro';
import Section from '../../components/Section.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ComparisonTable from '../../components/ui/ComparisonTable.astro';
import Icon from '../../components/ui/Icon.astro';
import { getSolution } from '../../data/solutions';

const solution = getSolution('atm-mortgage');

const risks = [
  {
    title: 'The rate is variable',
    text: 'Pricing is tied to an index plus a margin, so your interest cost moves with the market. A borrower who would lose sleep over a rate increase should choose a fixed-rate mortgage instead. We model what a two-point rise would do to your payment before you commit.',
  },
  {
    title: 'It requires real discipline',
    text: 'The strategy works because your surplus stays parked against the balance. If the open line becomes a spending account, the balance grows and you end up worse off than with a traditional mortgage. Be honest with yourself about this one.',
  },
  {
    title: 'There is a draw period',
    text: 'Lines have a defined draw period, after which the loan converts to a repayment schedule with a higher required payment. You need a plan for that transition from day one, not year nine.',
  },
  {
    title: 'It is not a payoff shortcut on its own',
    text: 'No account structure creates money. If your income and expenses are roughly equal each month, this will not accelerate your payoff. The engine is your surplus, and the account only makes that surplus work harder.',
  },
];
---

<ProgramLayout program={solution} kind="solution">
  <Section slot="after-benefits" bg="white">
    <SectionHeading
      eyebrow="Side by Side"
      title="First-Lien HELOC vs. Traditional Mortgage"
      align="center"
      class="mb-10"
    />
    <ComparisonTable
      headers={['Factor', 'ATM Mortgage (First-Lien HELOC)', 'Traditional Mortgage']}
      rows={[
        ['Lien position', 'First', 'First'],
        ['Structure', 'Revolving line of credit', 'Fixed installment loan'],
        ['Access to equity', 'Draw any time up to your limit', 'Requires refinance or a second lien'],
        ['Interest calculation', 'Average daily balance', 'Scheduled amortized balance'],
        ['Rate type', 'Variable', 'Usually fixed'],
        ['Effect of a large deposit', 'Immediately reduces interest-bearing balance', 'Applies as a principal payment on schedule'],
        ['Best for', 'Consistent surplus, self-employed, investors', 'Predictable budgets and long fixed horizons'],
      ]}
      highlightColumn={1}
    />

    <div class="mt-14 grid gap-8 lg:grid-cols-[1fr_1fr] lg:gap-12">
      <div>
        <SectionHeading
          eyebrow="Worked Example"
          title="What a Month Actually Looks Like"
          align="left"
          class="mb-6"
        />
        <div class="overflow-hidden rounded-card border border-silver-light bg-white shadow-card">
          <div class="bg-navy px-6 py-4">
            <h3 class="font-heading font-bold text-white">$400,000 line · $9,500 monthly income · $7,000 expenses</h3>
          </div>
          <ol class="divide-y divide-silver-light">
            {
              [
                ['Day 1', 'Balance starts the month at $400,000.'],
                ['Day 2', 'Income of $9,500 deposits. Balance drops to $390,500 and interest accrues on the lower figure.'],
                ['Days 3–30', 'Expenses are paid from the line as they come due, gradually raising the balance to about $397,500.'],
                ['Month end', 'The $2,500 surplus stays applied against the balance instead of sitting idle in checking.'],
                ['Ongoing', 'That surplus compounds against the balance each month, and it remains available to draw if you need it.'],
              ].map(([label, text]) => (
                <li class="px-6 py-4">
                  <span class="text-eyebrow font-heading font-semibold uppercase text-brandblue">{label}</span>
                  <p class="mt-1 text-[0.9375rem] leading-relaxed text-charcoal">{text}</p>
                </li>
              ))
            }
          </ol>
        </div>
        <p class="mt-4 text-sm text-graytext">
          Illustrative only. Actual results depend on your rate, spending pattern, and how consistently a surplus exists.
        </p>
      </div>

      <div>
        <SectionHeading
          eyebrow="Read This Part"
          title="Honest Risks & Considerations"
          align="left"
          subtitle="This product is genuinely excellent for some households and genuinely wrong for others. Here is the case against it."
          class="mb-6"
        />
        <div class="space-y-4">
          {
            risks.map((risk) => (
              <div class="flex gap-4 rounded-card border border-silver-light bg-offwhite p-6">
                <Icon name="alert-triangle" size={22} class="mt-0.5 shrink-0 text-gold" />
                <div>
                  <h3 class="font-heading font-bold text-navy">{risk.title}</h3>
                  <p class="mt-2 text-[0.9375rem] leading-relaxed text-graytext">{risk.text}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Section>
</ProgramLayout>
