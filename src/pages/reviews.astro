---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TestimonialCard from '../components/ui/TestimonialCard.astro';
import GoogleReviews from '../components/ui/GoogleReviews.astro';
import StatBar from '../components/ui/StatBar.astro';
import Icon from '../components/ui/Icon.astro';
import Button from '../components/Button.astro';
import { testimonials, testimonialCategories, testimonialDisclaimer } from '../data/testimonials';
import { breadcrumbSchema } from '../utils/seo';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Reviews', href: '/reviews' },
];

const partnerTestimonials = [
  {
    quote:
      'Jason answers the phone. That sounds like a low bar until you have had three deals nearly fall apart because a lender went dark during the option period.',
    author: 'Real Estate Agent',
    role: 'Williamson County',
  },
  {
    quote:
      'I refer clients to Jason when the financing question is complicated. He explains the options to them clearly enough that they come back to me able to make a decision.',
    author: 'Financial Advisor',
    role: 'Austin, TX',
  },
];
---

<PageLayout
  title="Client Reviews & Testimonials"
  description="Read reviews for Jason Herbert and The Herbert Team. Five-star Google ratings from first-time buyers, self-employed borrowers, veterans, and move-up buyers across Texas."
  heroEyebrow="Social Proof"
  heroTitle="Thousands of Closings. Here’s What They Said."
  heroSubtitle="Twenty years of files, and the feedback that means the most is almost never about the rate. It is about being answered, being explained to, and being told the truth."
  heroImage="/images/hero/about-hero.jpg"
  heroImageAlt="Happy family at their closing table"
  crumbs={crumbs}
  schema={breadcrumbSchema(crumbs)}
>
  <Section bg="offwhite">
    <StatBar class="mx-auto max-w-4xl" />

    <div class="mt-12">
      <SectionHeading
        eyebrow="Live From Google"
        title="Unfiltered Reviews"
        subtitle="These come straight from Google and are not curated by me. What you see here is what everyone else sees."
        align="center"
        class="mb-10"
      />
      <div class="rounded-card border border-silver-light bg-white p-4 shadow-card md:p-8">
        <GoogleReviews minHeight="700px" />
      </div>
    </div>
  </Section>

  <Section bg="white">
    <SectionHeading
      eyebrow="By Client Type"
      title="Filter by Situation Like Yours"
      subtitle="Different clients value different things. Filter to the situation closest to yours."
      align="center"
      class="mb-8"
    />

    <div class="mb-10 flex flex-wrap justify-center gap-2.5" role="group" aria-label="Filter reviews by client type">
      {
        testimonialCategories.map((category, index) => (
          <button
            type="button"
            class:list={[
              'min-h-[44px] rounded-full border px-5 py-2.5 font-heading text-sm font-semibold transition-colors',
              index === 0
                ? 'border-navy bg-navy text-white'
                : 'border-silver bg-white text-navy hover:border-brandblue hover:text-brandblue',
            ]}
            data-review-filter={category}
            aria-pressed={index === 0 ? 'true' : 'false'}
          >
            {category}
          </button>
        ))
      }
    </div>

    <ul class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        testimonials.map((testimonial) => (
          <li data-review-category={testimonial.category ?? 'All'}>
            <TestimonialCard {...testimonial} class="h-full" />
          </li>
        ))
      }
    </ul>

    <p class="mt-8 hidden text-center text-graytext" data-review-empty>
      No written testimonials in that category yet — the live Google widget above includes every review received.
    </p>
  </Section>

  <Section bg="offwhite">
    <div class="grid gap-8 lg:grid-cols-2 lg:gap-12">
      <div>
        <SectionHeading eyebrow="Video Reviews" title="Coming Soon" align="left" class="mb-6" />
        <div class="grid gap-5 sm:grid-cols-2">
          {
            [1, 2].map((slot) => (
              <div class="flex aspect-video flex-col items-center justify-center rounded-card border-2 border-dashed border-silver bg-white p-6 text-center">
                <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-brandblue-soft text-brandblue">
                  <Icon name="play" size={24} />
                </span>
                <p class="mt-3 text-sm text-graytext">
                  {/* TODO: Embed client video testimonial once footage is delivered. */}
                  Video testimonial slot {slot}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <div>
        <SectionHeading eyebrow="From Partners" title="What Agents and Advisors Say" align="left" class="mb-6" />
        <div class="space-y-5">
          {partnerTestimonials.map((item) => <TestimonialCard {...item} />)}
        </div>
      </div>
    </div>
  </Section>

  <Section bg="white" padding="sm">
    <div class="grid items-center gap-8 rounded-card border border-silver-light bg-offwhite p-7 shadow-card md:p-9 lg:grid-cols-[1.4fr_1fr]">
      <div>
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-gold/15 text-gold">
          <Icon name="star" size={24} class="fill-current" strokeWidth={0} />
        </span>
        <h2 class="mt-5 text-h3 font-bold text-navy">Worked With Me Before?</h2>
        <p class="mt-3 leading-relaxed text-graytext">
          A review takes two minutes and genuinely helps the next person who is trying to figure out whether to trust a
          stranger with the biggest loan of their life. If something could have gone better, I would rather hear that
          directly — my phone number is on every page of this site.
        </p>
      </div>
      <div class="flex flex-col gap-3">
        <Button
          href="https://www.google.com/search?q=The+Herbert+Team+Jason+Herbert+mortgage+Georgetown+TX"
          variant="primary"
          size="lg"
          external
          icon="arrow-right"
          fullWidth
        >
          Leave a Google Review
        </Button>
        <Button href="/contact" variant="secondary" size="lg" fullWidth>Send Me Private Feedback</Button>
      </div>
    </div>
    <p class="mx-auto mt-8 max-w-3xl text-center text-sm text-graytext">{testimonialDisclaimer}</p>
  </Section>
</PageLayout>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('[data-review-filter]');
  const items = document.querySelectorAll<HTMLElement>('[data-review-category]');
  const empty = document.querySelector<HTMLElement>('[data-review-empty]');

  filters.forEach((button) => {
    button.addEventListener('click', () => {
      const selected = button.dataset.reviewFilter;

      filters.forEach((other) => {
        const active = other === button;
        other.setAttribute('aria-pressed', String(active));
        other.classList.toggle('bg-navy', active);
        other.classList.toggle('text-white', active);
        other.classList.toggle('border-navy', active);
        other.classList.toggle('bg-white', !active);
        other.classList.toggle('text-navy', !active);
        other.classList.toggle('border-silver', !active);
      });

      let visible = 0;
      items.forEach((item) => {
        const show = selected === 'All' || item.dataset.reviewCategory === selected;
        item.classList.toggle('hidden', !show);
        if (show) visible += 1;
      });

      empty?.classList.toggle('hidden', visible > 0);
    });
  });
</script>
